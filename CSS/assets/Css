.footer {
  background: #0a0a0a;
  padding: 50px 20px;
  color: white;
  margin-top: 80px;
}

.footer-container {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20px;
}

.footer-logo span {
  color: #ff2d2d;
}

.footer-links ul {
  list-style: none;
  padding: 0;
}

.footer-links a {
  color: #aaa;
  text-decoration: none;
}

.footer-links a:hover {
  color: #fff;
}

.footer-bottom {
  text-align: center;
  margin-top: 30px;
  color: #777;
  font-size: 14px;
}
